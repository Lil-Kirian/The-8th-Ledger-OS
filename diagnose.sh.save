#!/bin/bas# Run: bash diagnose.sh

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[0;90m'
NC='\033[0m' # No Color

PASS=0
FAIL=0
WARN=0

echo ""
echo -e "${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║        VINCULUM OS — SYSTEM DIAGNOSTIC REPORT              ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Helper functions
check_file() {
    if [ -f "$1" ]; then
        echo -e "  ${GREEN}✓${NC} $2"
        ((PASS++))
    else
        echo -e "  ${RED}✗${NC} $2 ${DIM}→ $1 missing${NC}"
        ((FAIL++))
    fi
}

check_dir() {
    if [ -d "$1" ]; then
        echo -e "  ${GREEN}✓${NC} $2"
        ((PASS++))
    else
        echo -e "  ${RED}✗${NC} $2 ${DIM}→ $1 missing${NC}"
        ((FAIL++))
    fi
}

check_env_var() {
    if grep -q "$1" .env 2>/dev/null || grep -q "$1" .env.local 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $1 set"
        ((PASS++))
    else
        echo -e "  ${RED}✗${NC} $1 ${DIM}→ not found in .env or .env.local${NC}"
        ((FAIL++))
    fi
}

check_pkg() {
    if grep -q "\"$1\"" package.json 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} $1"
        ((PASS++))
    else
        echo -e "  ${RED}✗${NC} $1 ${DIM}→ not in package.json${NC}"
        ((FAIL++))
    fi
}

# ─── PROJECT STRUCTURE ───
echo -e "${CYAN}▸ PROJECT STRUCTURE${NC}"
check_dir "app" "App directory"
check_dir "app/(auth)" "Auth route group"
check_dir "app/(dashboard)" "Dashboard route group"
check_dir "app/api" "API routes"
check_dir "prisma" "Prisma directory"
check_file "prisma/schema.prisma" "Prisma schema"
check_dir "components" "Components directory"
check_dir "components/ui" "UI components"
check_dir "components/layout" "Layout components"
check_dir "lib" "Lib directory"
check_dir "types" "Types directory"
check_dir "hooks" "Hooks directory"
echo ""

# ─── CORE FILES ───
echo -e "${CYAN}▸ CORE FILES${NC}"
check_file "next.config.ts" "Next.js config"
check_file "tsconfig.json" "TypeScript config"
check_file "tailwind.config.ts" "Tailwind config"
check_file "postcss.config.mjs" "PostCSS config"
check_file ".env" "Environment file"
check_file ".env.local" "Local environment file"
check_file "package.json" "Package manifest"
echo ""

# ─── LIBRARY FILES ───
echo -e "${CYAN}▸ LIBRARY FILES${NC}"
check_file "lib/prisma.ts" "Prisma client singleton"
check_file "lib/utils.ts" "Tailwind utils (cn)"
check_file "lib/auth.ts" "Auth helpers (JWT, bcrypt)"
echo ""

# ─── HOOKS ───
echo -e "${CYAN}▸ CUSTOM HOOKS${NC}"
check_file "hooks/use-auth.ts" "useAuth hook"
echo ""

# ─── TYPES ───
echo -e "${CYAN}▸ TYPE DEFINITIONS${NC}"
check_file "types/index.ts" "Global types"
echo ""

# ─── LAYOUT COMPONENTS ───
echo -e "${CYAN}▸ LAYOUT COMPONENTS${NC}"
check_file "components/layout/navbar.tsx" "Navbar"
check_file "components/layout/sidebar.tsx" "Sidebar"
check_file "components/layout/dashboard-shell.tsx" "Dashboard shell"
echo ""

# ─── UI COMPONENTS ───
echo -e "${CYAN}▸ UI COMPONENTS${NC}"
check_file "components/ui/button.tsx" "Button"
check_file "components/ui/input.tsx" "Input"
check_file "components/ui/card.tsx" "Card"
check_file "components/ui/badge.tsx" "Badge"
echo ""

# ─── AUTH PAGES ───
echo -e "${CYAN}▸ AUTH PAGES${NC}"
check_file "app/(auth)/enter/page.tsx" "Enter page"
check_file "app/(auth)/create/page.tsx" "Create account page"
check_file "app/(auth)/layout.tsx" "Auth layout"
echo ""

# ─── DASHBOARD PAGES ───
echo -e "${CYAN}▸ DASHBOARD PAGES${NC}"
check_file "app/(dashboard)/exchange/page.tsx" "Exchange"
check_file "app/(dashboard)/pools/page.tsx" "Pools"
check_file "app/(dashboard)/forge/page.tsx" "Forge"
check_file "app/(dashboard)/vault/page.tsx" "Vault"
check_file "app/(dashboard)/knot/page.tsx" "Knot"
check_file "app/(dashboard)/audit/page.tsx" "Audit"
check_file "app/(dashboard)/layout.tsx" "Dashboard layout"
echo ""

# ─── API ROUTES ───
echo -e "${CYAN}▸ API ROUTES${NC}"
check_file "app/api/auth/route.ts" "Auth API"
check_file "app/api/auth/me/route.ts" "Auth Me API"
check_file "app/api/exchange/orders/route.ts" "Exchange orders"
check_file "app/api/exchange/trades/route.ts" "Exchange trades"
check_file "app/api/pools/route.ts" "Pools API"
check_file "app/api/predictions/route.ts" "Predictions API"
echo ""

# ─── DEPENDENCIES ───
echo -e "${CYAN}▸ DEPENDENCIES${NC}"
check_pkg "@prisma/client"
check_pkg "prisma"
check_pkg "framer-motion"
check_pkg "zustand"
check_pkg "swr"
check_pkg "recharts"
check_pkg "lucide-react"
check_pkg "bcryptjs"
check_pkg "jose"
check_pkg "uuid"
check_pkg "clsx"
check_pkg "tailwind-merge"
check_pkg "tailwindcss-animate"
echo ""

# ─── ENVIRONMENT VARIABLES ───
echo -e "${CYAN}▸ ENVIRONMENT VARIABLES${NC}"
check_env_var "DATABASE_URL"
check_env_var "JWT_SECRET"
check_env_var "NEXT_PUBLIC_APP_URL"
echo ""

# ─── TSCONFIG PATHS ───
echo -e "${CYAN}▸ TSCONFIG CHECK${NC}"
if [ -f "tsconfig.json" ]; then
    if grep -q '"@/\*"' tsconfig.json; then
        echo -e "  ${GREEN}✓${NC} Path alias @/* configured"
        ((PASS++))
    else
        echo -e "  ${RED}✗${NC} Path alias @/* missing"
        ((FAIL++))
    fi
    
    if grep -q '"baseUrl"' tsconfig.json; then
        echo -e "  ${GREEN}✓${NC} baseUrl set"
        ((PASS++))
    else
        echo -e "  ${RED}✗${NC} baseUrl missing"
        ((FAIL++))
    fi
else
    echo -e "  ${RED}✗${NC} tsconfig.json not found"
    ((FAIL++))
fi
echo ""

# ─── PRISMA GENERATION ───
echo -e "${CYAN}▸ PRISMA CLIENT${NC}"
if [ -d "node_modules/@prisma/client" ] || [ -d "src/generated/prisma" ] || [ -d "generated/prisma" ]; then
    echo -e "  ${GREEN}✓${NC} Prisma Client generated"
    ((PASS++))
else
    echo -e "  ${YELLOW}⚠${NC} Prisma Client not generated ${DIM}→ run: npx prisma generate${NC}"
    ((WARN++))
fi
echo ""

# ─── DATABASE CONNECTION ───
echo -e "${CYAN}▸ DATABASE CONNECTION${NC}"
if command -v npx &> /dev/null && [ -f "prisma/schema.prisma" ]; then
    if npx prisma db execute --stdin <<< "SELECT 1" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Database reachable"
        ((PASS++))
    else
        echo -e "  ${YELLOW}⚠${NC} Database unreachable ${DIM}→ check DATABASE_URL${NC}"
        ((WARN++))
    fi
else
    echo -e "  ${YELLOW}⚠${NC} Could not test database ${DIM}→ npx or schema missing${NC}"
    ((WARN++))
fi
echo ""

# ─── GIT STATUS ───
echo -e "${CYAN}▸ GIT STATUS${NC}"
if [ -d ".git" ]; then
    UNTRACKED=$(git status --short 2>/dev/null | wc -l | tr -d ' ')
    if [ "$UNTRACKED" -gt 0 ]; then
        echo -e "  ${YELLOW}⚠${NC} $UNTRACKED uncommitted changes"
        ((WARN++))
    else
        echo -e "  ${GREEN}✓${NC} Working tree clean"
        ((PASS++))
    fi
else
    echo -e "  ${YELLOW}⚠${NC} Not a git repository"
    ((WARN++))
fi
echo ""

# ─── SUMMARY ───
echo -e "${CYAN}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║                      DIAGNOSIS COMPLETE                      ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "  ${GREEN}$PASS passing${NC}  |  ${RED}$FAIL failing${NC}  |  ${YELLOW}$WARN warnings${NC}"
echo ""

if [ $FAIL -eq 0 ] && [ $WARN -eq 0 ]; then
    echo -e "  ${GREEN}🚀 SYSTEM FULLY OPERATIONAL${NC}"
    echo -e "  ${DIM}All files present. All dependencies installed. Ready to build.${NC}"
elif [ $FAIL -eq 0 ]; then
    echo -e "  ${YELLOW}⚡ SYSTEM MOSTLY READY${NC}"
    echo -e "  ${DIM}Fix warnings above, then run: npm run dev${NC}"
else
    echo -e "  ${RED}🔧 SYSTEM INCOMPLETE${NC}"
    echo -e "  ${DIM}Create missing files above, then run: npm run dev${NC}"
fi

echo ""
echo -e "${DIM}Tip: Run 'npx prisma generate' after fixing schema issues.${NC}"
echo -e "${DIM}Tip: Run 'npm install' if dependencies are missing.${NC}"
echo ""
