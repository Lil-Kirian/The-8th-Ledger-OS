# Copy this file to .env and replace every placeholder before running the app.
# Do not commit real .env files or real secret values.

# PostgreSQL
POSTGRES_USER="replace-with-postgres-user"
POSTGRES_PASSWORD="replace-with-strong-postgres-password"
POSTGRES_DB="replace-with-postgres-db"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
WEB_PORT="3000"

# Used by Prisma when running commands directly on the host.
DATABASE_URL="postgresql://replace-with-postgres-user:replace-with-url-encoded-postgres-password@localhost:5432/replace-with-postgres-db?schema=public"

# Application secrets
SESSION_SECRET="replace-with-at-least-32-random-characters"
TOTP_ENCRYPTION_KEY="replace-with-at-least-32-random-characters"
CRON_SECRET="replace-with-at-least-24-random-characters"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
WORKER_APP_URL="http://web:3000"

# Paystack is optional locally. Required for live payments.
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_IPS=""
