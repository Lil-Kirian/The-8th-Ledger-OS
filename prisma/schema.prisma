// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. SOVEREIGN IDENTITY
// ============================================================

model User {
  id              String    @id @default(cuid())
  ledgerId        String    @unique
  displayName     String
  email           String    @unique
  passwordHash    String
  country         String
  phone           String?
  trustScore      Int       @default(100)
  tier            Int       @default(1)
  ledgerBalance   Int       @default(0)
  creditPool      Int       @default(0)
  forgesCompleted Int       @default(0)
  referrals       Int       @default(0)
  referredBy      String?
  lastLoginAt     DateTime?
  lastLoginIP     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  totpSecret    String?
  totpEnabled   Boolean @default(false)
  totpVerified  Boolean @default(false)
  recoveryCodes String?

  bio              String?
  preferences      String?
  avatar           String?
  totalCommitted   Int     @default(0)
  reportsSubmitted Int     @default(0)

  identityScore  Int       @default(0)
  kycStatus      String    @default("unverified")
  kycVerifiedAt  DateTime?
  role           String    @default("user")
  isPrimaryAdmin Boolean   @default(false)

  legalName         String?
  idNumber          String?
  idDocumentUrl     String?
  addressProofUrl   String?
  selfieUrl         String?
  livenessVerified  Boolean  @default(false)
  kycTier           String   @default("visitor")
  lastActivityAt    DateTime @default(now())
  deviceFingerprint String?
  isBanned          Boolean  @default(false)
  banReason         String?
  beneficiaryName   String?
  beneficiaryEmail  String?

  adminTotpSecret   String?
  adminTotpEnabled  Boolean   @default(false)
  adminPinHash      String?
  adminPinAttempts  Int       @default(0)
  adminLockedUntil  DateTime?
  lastAdminAccessAt DateTime?
  lastAdminIP       String?
  adminAccessCount  Int       @default(0)

  founderTotpSecret        String?
  founderTotpEnabled       Boolean   @default(false)
  founderPinHash           String?
  webauthnCredentialId     String?
  webauthnPublicKey        String?
  webauthnCounter          Int       @default(0)
  lastFounderAccessAt      DateTime?
  lastFounderIP            String?
  founderAccessCount       Int       @default(0)
  founderPinAttempts       Int       @default(0)
  founderLockedUntil       DateTime?
  founderAccessWindowStart Int?
  founderAccessWindowEnd   Int?
  founderTrustedLat        Float?
  founderTrustedLng        Float?
  founderGeoRadiusKm       Int       @default(50)

  globalSriScore Int @default(0)

  sessions        Session[]
  orders          Order[]
  tradesAsBuyer   Trade[]             @relation("BuyerTrades")
  tradesAsSeller  Trade[]             @relation("SellerTrades")
  rewardsReceived ReferralReward[]    @relation("RewardTo")
  rewardsSent     ReferralReward[]    @relation("RewardFrom")
  reviews         Review[]
  activities      ActivityEvent[]
  milestones      TierMilestone[]
  withdrawals     WithdrawalRequest[]
  auditEntries    AuditEntry[]
  auditLogs       AuditLog[]
  knotMembership  KnotMember?
  poolReviews     PoolReview[]
  wallet          Wallet?
  assetReports    AssetReport[]
  disputes        Dispute[]
  notifications   Notification[]
  quantumMerit    QuantumMeritScore?
  userIdentity    UserIdentity?

  hallMessages      HallMessage[]
  proposals         Proposal[]
  votes             Vote[]
  ownerships        Ownership[]
  socialShares      SocialShare[]
  banRecords        BanRecord[]
  bannedUsers       BanRecord[]        @relation("Banner")
  hallRoles         HallRole[]
  kycRecord         KycRecord?
  hallActivities    HallActivity[]
  hallInvites       HallInvite[]
  securityAuditLogs SecurityAuditLog[]

  oraclePredictions    OraclePrediction[]
  oracleStanding       OracleStanding?
  dormancyVaults       DormancyVault[]
  agoraSuggestions     AgoraSuggestion[]
  agoraQAs             AgoraQA[]
  agoraSuggestionVotes AgoraSuggestionVote[]
  liquidationPayouts   LiquidationPayout[]
  inventoryOrders      InventoryOrder[]
  ownershipListings    OwnershipListing[]
  boughtListings       OwnershipListing[]    @relation("ListingBuyer")
  sovereignStreamPosts SovereignStreamPost[]
  boughtAuctions       DormancyAuction[]     @relation("AuctionBuyer")
  hallContributions    HallContribution[]

  @@index([ledgerId])
  @@index([email])
  @@index([tier])
  @@index([trustScore])
  @@index([kycStatus])
  @@map("users")
}

model Session {
  id                String   @id @default(cuid())
  token             String   @unique
  ledgerId          String
  user              User     @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)
  expiresAt         DateTime
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  geoCountry        String?
  geoCity           String?
  lastUsedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  rotationCount     Int      @default(0)
  isRevoked         Boolean  @default(false)
  anomalyFlags      String?

  @@index([token])
  @@index([ledgerId])
  @@index([expiresAt])
  @@index([isRevoked])
  @@map("sessions")
}

model Wallet {
  id            String   @id @default(cuid())
  ledgerId      String   @unique
  balance       Float    @default(0)
  lockedBalance Float    @default(0)
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User         @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)
  deposits Deposit[]
  payouts  Withdrawal[]

  @@index([ledgerId])
  @@map("wallets")
}

model LedgerEntry {
  id             String   @id @default(cuid())
  ledgerId       String
  walletId       String?
  type           String
  direction      String
  amount         Decimal  @db.Decimal(18, 2)
  currency       String   @default("USD")
  status         String   @default("posted")
  referenceType  String?
  referenceId    String?
  idempotencyKey String?  @unique
  description    String
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([ledgerId])
  @@index([walletId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("ledger_entries")
}

model Deposit {
  id          String    @id @default(cuid())
  walletId    String
  ledgerId    String
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending")
  method      String    @default("bank_transfer")
  reference   String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([ledgerId])
  @@index([status])
  @@map("deposits")
}

model Withdrawal {
  id              String    @id @default(cuid())
  walletId        String
  ledgerId        String
  amount          Float
  currency        String    @default("USD")
  status          String    @default("pending")
  destination     String
  destinationType String    @default("bank")
  reference       String?
  createdAt       DateTime  @default(now())
  processedAt     DateTime?
  processedBy     String?
  rejectionReason String?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([ledgerId])
  @@index([status])
  @@map("withdrawals")
}

// ============================================================
// 2. POOL — Asset Pools
// ============================================================

model Pool {
  id              String    @id @default(cuid())
  poolId          String    @unique
  verticalId      String
  name            String
  description     String    @default("")
  imageUrl        String?
  assetValue      Int
  committed       Int       @default(0)
  target          Int
  participants    Int       @default(0)
  maxParticipants Int
  status          String    @default("filling")
  country         String
  creatorId       String
  isVerified      Boolean   @default(false)
  reportedCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  closesAt        DateTime
  distributedAt   DateTime?

  trueCost         Int?
  listedPrice      Int?
  surplus          Int?
  spv              SpvEntity?
  managementFee    Float      @default(20.00)
  minCommitment    Int        @default(1)
  maxCommitment    Int?
  campaignDuration Int        @default(30)
  emojiSet         String     @default("🏠🚗📱🎓🏥🏗️✈️🌾⚡")
  hallUnlocked     Boolean    @default(false)
  selectedLocation String?
  externalLinks    String?
  assetImages      String?
  assetVideos      String?
  tour360Url       String?
  documents        String?
  assetCondition   String     @default("new")

  assetType      String?
  revenueSources String?

  hallClass      String?
  pirAllocation  String?
  assetBookValue Int     @default(0)

  insuranceAllocation Int?
  executionQueue      String?

  ihcpTarget Int?

  treasuryTxs   TreasuryTransaction[]
  auditEntries  AuditEntry[]
  auditLogs     AuditLog[]
  poolReviews   PoolReview[]
  disputes      Dispute[]
  notifications Notification[]

  hall                Hall?
  assetReports        AssetReport[]
  ownerships          Ownership[]
  proposals           Proposal[]
  revenueLogs         RevenueLog[]
  insuranceFunds      InsuranceFund[]
  locationOptionsList LocationOption[]

  cyclePools       CyclePool[]
  marketplaceItems MarketplaceItem[]

  @@index([verticalId])
  @@index([status])
  @@index([country])
  @@index([closesAt])
  @@index([isVerified])
  @@map("pools")
}

// ============================================================
// 3. EXCHANGE
// ============================================================

model Order {
  id        String   @id @default(cuid())
  side      String
  ledgerId  String
  amount    Int
  price     Float
  filled    Int      @default(0)
  status    String   @default("open")
  createdAt DateTime @default(now())
  txHash    String   @unique

  user       User    @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)
  buyTrades  Trade[] @relation("BuyOrder")
  sellTrades Trade[] @relation("SellOrder")

  @@index([ledgerId])
  @@index([status])
  @@index([side])
  @@index([createdAt])
  @@map("orders")
}

model Trade {
  id          String   @id @default(cuid())
  buyOrderId  String
  sellOrderId String
  amount      Int
  price       Float
  total       Float
  buyerId     String
  sellerId    String
  executedAt  DateTime @default(now())
  txHash      String   @unique

  buyOrder  Order @relation("BuyOrder", fields: [buyOrderId], references: [id])
  sellOrder Order @relation("SellOrder", fields: [sellOrderId], references: [id])
  buyer     User  @relation("BuyerTrades", fields: [buyerId], references: [ledgerId])
  seller    User  @relation("SellerTrades", fields: [sellerId], references: [ledgerId])

  @@index([buyerId])
  @@index([sellerId])
  @@index([executedAt])
  @@map("trades")
}

// ============================================================
// 4. KNOT & REFERRALS
// ============================================================

model KnotMember {
  id             String   @id @default(cuid())
  ledgerId       String   @unique
  displayName    String
  country        String
  tier           Int
  joinedAt       DateTime @default(now())
  totalCommitted Int      @default(0)
  poolsWon       Int      @default(0)
  trustScore     Int      @default(100)
  referrals      Int      @default(0)
  depth          Int      @default(1)
  status         String   @default("active")
  referredBy     String?

  user User? @relation(fields: [ledgerId], references: [ledgerId])

  @@index([referredBy])
  @@index([depth])
  @@map("knot_members")
}

model ReferralReward {
  id              String   @id @default(cuid())
  toLedgerId      String
  fromLedgerId    String
  fromDisplayName String
  type            String
  amount          Int
  rewardPercent   Float
  rewardAmount    Float
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  toUser   User @relation("RewardTo", fields: [toLedgerId], references: [ledgerId])
  fromUser User @relation("RewardFrom", fields: [fromLedgerId], references: [ledgerId])

  @@index([toLedgerId])
  @@index([fromLedgerId])
  @@index([status])
  @@map("referral_rewards")
}

// ============================================================
// 5. TREASURY & AUDIT
// ============================================================

model TreasuryTransaction {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  currency    String   @default("USD")
  poolId      String?
  ledgerId    String?
  description String
  status      String   @default("completed")
  txHash      String   @unique
  timestamp   DateTime @default(now())
  audited     Boolean  @default(false)

  pool Pool? @relation(fields: [poolId], references: [poolId])

  @@index([type])
  @@index([ledgerId])
  @@index([timestamp])
  @@map("treasury_transactions")
}

model WithdrawalRequest {
  id              String    @id @default(cuid())
  ledgerId        String
  displayName     String
  amount          Int
  destination     String
  destinationType String    @default("bank")
  status          String    @default("pending")
  requestedAt     DateTime  @default(now())
  processedAt     DateTime?
  processedBy     String?
  rejectionReason String?

  user User @relation(fields: [ledgerId], references: [ledgerId])

  @@index([ledgerId])
  @@index([status])
  @@index([requestedAt])
  @@map("withdrawal_requests")
}

model ActivityEvent {
  id          String   @id @default(cuid())
  ledgerId    String
  date        DateTime @default(now())
  type        String
  title       String
  detail      String
  description String?
  metadata    String?
  amount      Int?
  points      Int?

  user User @relation(fields: [ledgerId], references: [ledgerId])

  @@index([ledgerId])
  @@index([type])
  @@index([date])
  @@map("activity_events")
}

model Review {
  id           String   @id @default(cuid())
  ledgerId     String
  propertyName String
  verticalId   String
  rating       Int
  text         String
  date         DateTime @default(now())
  helpful      Int      @default(0)
  reported     Boolean  @default(false)
  status       String   @default("visible")

  user User @relation(fields: [ledgerId], references: [ledgerId])

  @@index([ledgerId])
  @@index([verticalId])
  @@index([status])
  @@map("reviews")
}

model TierMilestone {
  id          String   @id @default(cuid())
  ledgerId    String
  tier        Int
  name        String
  date        DateTime @default(now())
  trustScore  Int
  triggeredBy String

  user User @relation(fields: [ledgerId], references: [ledgerId])

  @@index([ledgerId])
  @@index([tier])
  @@map("tier_milestones")
}

model AuditEntry {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  type         String
  description  String
  amount       Int?
  txHash       String   @unique
  previousHash String?
  ledgerId     String?
  poolId       String?

  user User? @relation(fields: [ledgerId], references: [ledgerId])
  pool Pool? @relation(fields: [poolId], references: [id])

  @@index([type])
  @@index([timestamp])
  @@index([txHash])
  @@index([poolId])
  @@index([previousHash])
  @@map("audit_entries")
}

model AuditLog {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  eventType       String
  description     String
  poolId          String?
  ledgerId        String?
  amount          Int?
  metadata        String?
  txHash          String   @unique
  visibleToPublic Boolean  @default(true)

  pool Pool? @relation(fields: [poolId], references: [id])
  user User? @relation(fields: [ledgerId], references: [ledgerId])

  @@index([eventType])
  @@index([timestamp])
  @@index([txHash])
  @@index([poolId])
  @@index([visibleToPublic])
  @@map("audit_logs")
}

model ProtocolSettings {
  id                 String   @id @default(cuid())
  key                String   @unique
  platformFee        Int      @default(0)
  minCommitment      Int      @default(50)
  maxCommitment      Int      @default(50000)
  consensusThreshold Int      @default(2)
  publicAudit        Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  updatedBy          String?

  pirEnabled              Boolean @default(true)
  oracleEnabled           Boolean @default(true)
  meridianCycleEnabled    Boolean @default(true)
  closureProtocolEnabled  Boolean @default(true)
  dormancyProtocolEnabled Boolean @default(true)
  dynamicValuationEnabled Boolean @default(true)
  forgeLedgerEnabled      Boolean @default(true)
  eighthLedgerTithe       Int     @default(20)

  @@map("protocol_settings")
}

model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  ownerId   String
  uses      Int       @default(0)
  maxUses   Int       @default(50)
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([ownerId])
  @@index([code])
  @@map("invite_codes")
}

model PoolReview {
  id        String   @id @default(cuid())
  poolId    String
  ledgerId  String
  rating    Int
  title     String?
  content   String
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pool Pool @relation(fields: [poolId], references: [poolId], onDelete: Cascade)
  user User @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)

  @@unique([poolId, ledgerId])
  @@index([poolId])
  @@index([ledgerId])
  @@map("pool_reviews")
}

model VerticalConfig {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  icon          String?
  color         String?
  minCommitment Int      @default(50)
  maxCommitment Int      @default(50000)
  hallClass     String   @default("I")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([slug])
  @@index([isActive])
  @@map("vertical_configs")
}

model UserIdentity {
  id                String    @id @default(cuid())
  ledgerId          String    @unique
  kycStatus         String    @default("unverified")
  verificationTier  Int       @default(0)
  idDocumentUrl     String?
  selfieUrl         String?
  proofOfAddressUrl String?
  verifiedAt        DateTime?
  verifiedBy        String?
  rejectionReason   String?
  identityScore     Int       @default(0)
  countryVerified   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)

  @@index([ledgerId])
  @@index([kycStatus])
  @@map("user_identities")
}

model QuantumMeritScore {
  id                    String   @id @default(cuid())
  ledgerId              String   @unique
  ownershipBase         Int      @default(0)
  poolHistoryScore      Int      @default(0)
  communityScore        Int      @default(0)
  reviewQualityScore    Int      @default(0)
  identityScore         Int      @default(0)
  arcStreakScore        Int      @default(0)
  countryDiversityScore Int      @default(0)
  totalMeritScore       Int      @default(0)
  lastPoolId            String?
  calculatedAt          DateTime @updatedAt

  user User @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)

  @@index([ledgerId])
  @@index([totalMeritScore])
  @@map("quantum_merit_scores")
}

model AssetReport {
  id          String    @id @default(cuid())
  poolId      String
  ledgerId    String
  reason      String
  description String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?

  pool Pool @relation(fields: [poolId], references: [poolId], onDelete: Cascade)
  user User @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)

  @@index([poolId])
  @@index([ledgerId])
  @@index([status])
  @@map("asset_reports")
}

model Dispute {
  id          String    @id @default(cuid())
  poolId      String
  ledgerId    String
  type        String
  description String
  evidence    String?
  status      String    @default("open")
  resolution  String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?

  pool Pool @relation(fields: [poolId], references: [poolId], onDelete: Cascade)
  user User @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)

  @@index([poolId])
  @@index([ledgerId])
  @@index([status])
  @@map("disputes")
}

model Notification {
  id         String   @id @default(cuid())
  ledgerId   String
  poolId     String?
  proposalId String?
  type       String
  title      String
  message    String
  read       Boolean  @default(false)
  actionUrl  String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)
  pool     Pool?     @relation(fields: [poolId], references: [id], onDelete: SetNull)
  proposal Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([ledgerId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
  @@index([proposalId])
  @@map("notifications")
}

// ============================================================
// 6. HALL & GOVERNANCE
// ============================================================

model Hall {
  id        String   @id @default(cuid())
  poolId    String   @unique
  pool      Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  name      String
  status    String   @default("ghost")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hallClass      String?
  sriScore       Int     @default(50)
  ahgiScore      Int     @default(50)
  closureStatus  String  @default("active")
  pirDebt        Int     @default(0)
  payrollReserve Int     @default(0)

  assetType      String?
  businessStatus String  @default("operating")

  inventoryEnabled Boolean @default(false)
  forgeEnabled     Boolean @default(false)
  ihcpBalance      Int     @default(0)

  deedUrl                 String?
  insuranceCertificateUrl String?
  spvAgreementUrl         String?
  constitutionUrl         String?

  messages        HallMessage[]
  proposals       Proposal[]
  hallTreasury    HallTreasury?
  ownerships      Ownership[]
  banRecords      BanRecord[]
  hallInvites     HallInvite[]
  hallActivities  HallActivity[]
  hallRoles       HallRole[]
  locationOptions LocationOption[]
  executionLogs   ExecutionLog[]

  executiveCabinet     ExecutiveCabinet?
  workers              Worker[]
  forgeLedgers         ForgeLedger[]
  relayMessages        RelayMessage[]
  sriSnapshots         SriSnapshot[]
  ahgiSnapshots        AhgiSnapshot[]
  dynamicValuations    DynamicValuation[]
  pirAllocations       PirAllocation[]
  pirAdvances          PirAdvance[]
  closureProtocols     ClosureProtocol[]
  eighthLedgerUpdates  EighthLedgerUpdate[]
  inventoryItems       InventoryItem[]
  ownershipListings    OwnershipListing[]
  sovereignStreamPosts SovereignStreamPost[]
  hallContributions    HallContribution[]
  marketplaceItems     MarketplaceItem[]

  @@index([poolId])
  @@map("halls")
}

model HallMessage {
  id            String    @id @default(cuid())
  hallId        String
  hall          Hall      @relation(fields: [hallId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String
  type          String    @default("text")
  watermarkHash String
  isEphemeral   Boolean   @default(false)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([hallId, createdAt])
  @@map("hall_messages")
}

model Proposal {
  id         String  @id @default(cuid())
  poolId     String
  pool       Pool    @relation(fields: [poolId], references: [id], onDelete: Cascade)
  hallId     String?
  hall       Hall?   @relation(fields: [hallId], references: [id])
  proposerId String
  proposer   User    @relation(fields: [proposerId], references: [id])

  title          String
  description    String
  type           String
  amount         Int?
  targetUserId   String?
  locationOption String?

  voteWeightYes    Float  @default(0)
  voteWeightNo     Float  @default(0)
  voteCountYes     Int    @default(0)
  voteCountNo      Int    @default(0)
  thresholdPercent Float  @default(51.00)
  status           String @default("pending")

  executionStatus String?   @default("pending")
  executedAt      DateTime?
  executionResult String?
  executionCost   Int?
  executionProof  String?
  executionNotes  String?
  stalledReason   String?
  startedAt       DateTime?
  completedAt     DateTime?
  passedAt        DateTime?
  executedBy      String?

  createdAt DateTime @default(now())
  endsAt    DateTime

  votes         Vote[]
