  author     User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  proposalId String?
  proposal   Proposal?             @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  parentId   String?
  parent     SovereignStreamPost?  @relation("PostReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies    SovereignStreamPost[] @relation("PostReplies")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@index([hallId])
  @@index([type])
  @@index([authorId])
  @@index([proposalId])
  @@index([parentId])
  @@map("sovereign_stream_posts")
}

model InventoryItem {
  id           String   @id @default(cuid())
  hallId       String
  hall         Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade)
  title        String
  description  String
  price        Int
  quantity     Int      @default(1)
  quantitySold Int      @default(0)
  status       String   @default("active")
  listedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  costOfGoods      Int @default(0)
  reorderThreshold Int @default(0)

  imageUrl String?
  images   String? // JSON array string
  tags     String? // JSON array string
  specs    String? // JSON object string

  orders       InventoryOrder[]
  socialShares SocialShare[]

  @@index([hallId])
  @@index([status])
  @@map("inventory_items")
}

model MarketplaceItem {
  id           String   @id @default(cuid())
  poolId       String?
  pool         Pool?    @relation(fields: [poolId], references: [id], onDelete: SetNull)
  hallId       String
  hall         Hall     @relation(fields: [hallId], references: [id], onDelete: Cascade)
  title        String
  description  String
  price        Int
  quantity     Int      @default(1)
  quantitySold Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([hallId])
  @@index([poolId])
  @@index([status])
  @@map("marketplace_items")
}

model InventoryOrder {
  id               String        @id @default(cuid())
  inventoryId      String
  inventory        InventoryItem @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  buyerId          String
  buyer            User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  amount           Int
  quantity         Int
  status           String        @default("pending")
  escrowReleasedAt DateTime?
  createdAt        DateTime      @default(now())
  completedAt      DateTime?

  platformFee     Int @default(0)
  fulfillmentCost Int @default(0)
  netToHall       Int @default(0)

  @@index([inventoryId])
  @@index([buyerId])
  @@index([status])
  @@map("inventory_orders")
}

model OwnershipListing {
  id              String    @id @default(cuid())
  ownershipId     String
  ownership       Ownership @relation(fields: [ownershipId], references: [id], onDelete: Cascade)
  hallId          String
  hall            Hall      @relation(fields: [hallId], references: [id], onDelete: Cascade)
  sellerId        String
  seller          User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  percentListed   Float
  pricePerPercent Float
  totalPrice      Float
  floorPrice      Float
  status          String    @default("active")
  listedAt        DateTime  @default(now())
  expiresAt       DateTime?
  soldAt          DateTime?
  buyerId         String?
  buyer           User?     @relation("ListingBuyer", fields: [buyerId], references: [id], onDelete: SetNull)

  escrowStartedAt    DateTime?
  escrowExpiresAt    DateTime?
  auditHash          String?   @unique
  belowFloorApproved Boolean   @default(false)
  viewCount          Int       @default(0)
  interestCount      Int       @default(0)
  isFractional       Boolean   @default(false)
  sellerKycTier      String?

  @@index([hallId])
  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([ownershipId])
  @@map("ownership_listings")
}

// ============================================================
// 8. IHCP — INTERNAL HALL CONTRIBUTION POOL (PHASE 4)
// ============================================================

model HallContribution {
  id       String @id @default(cuid())
  hallId   String
  hall     Hall   @relation(fields: [hallId], references: [id], onDelete: Cascade)
  ledgerId String
  user     User   @relation(fields: [ledgerId], references: [ledgerId], onDelete: Cascade)

  amount       Int
  purpose      String
  repaidAmount Int    @default(0)
  status       String @default("active")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hallId])
  @@index([ledgerId])
  @@index([status])
  @@map("hall_contributions")
}
